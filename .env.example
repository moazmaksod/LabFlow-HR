# Environment
NODE_ENV="development"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Server Configuration
PORT=3000
DB_PATH="labflow.db"
JWT_SECRET="your_super_secret_jwt_key_here"

# Timezone Configuration (Strictly used for all date-time generation and formatting)
APP_TIMEZONE="Africa/Cairo"

# Admin Bootstrapping
ADMIN_NAME="Super Admin"
ADMIN_EMAIL="admin@labflow.com"
ADMIN_PASSWORD="securepassword123"

# Default Global Settings Seeding
DEFAULT_LATE_GRACE_PERIOD=0
DEFAULT_GEOFENCE_RADIUS=100
DEFAULT_GEOFENCE_LAT=30.0444
DEFAULT_GEOFENCE_LNG=31.2357