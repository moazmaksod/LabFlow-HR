# Backend API URL
# For local development on a physical device, use your computer's local IP address instead of localhost
# Example: http://192.168.1.100:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Google Maps API Key (Required for Geofencing/Maps)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
